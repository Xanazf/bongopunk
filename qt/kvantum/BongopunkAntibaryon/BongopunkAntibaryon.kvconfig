[%General]
author=Xanazf
comment=Bongopunk Antibaryon - Dark theme with glow effects
x11drag=menubar_and_primary_toolbar
alt_mnemonic=true
left_tabs=true
attach_active_tab=true
mirror_doc_tabs=true
group_toolbar_buttons=true
toolbar_item_spacing=0
toolbar_interior_spacing=2
spread_progressbar=true
composite=true
menu_shadow_depth=2
tooltip_shadow_depth=2
splitter_width=1
scroll_width=12
scroll_arrows=false
scroll_min_extent=36
slider_width=6
slider_handle_width=16
slider_handle_length=16
center_toolbar_handle=true
check_size=16
textless_progressbar=false
progressbar_thickness=2
menubar_mouse_tracking=true
toolbutton_style=1
double_click=false
translucent_windows=true
blurring=true
popup_blurring=true
vertical_spin_indicators=false
spin_button_width=16
fill_rubberband=false
merge_menubar_with_toolbar=true
small_icon_size=16
large_icon_size=32
button_icon_size=16
toolbar_icon_size=16
combo_as_lineedit=true
animate_states=true
button_contents_shift=false
combo_menu=true
hide_combo_checkboxes=true
combo_focus_rect=true
groupbox_top_label=true
inline_spin_indicators=true
joined_inactive_tabs=true
layout_spacing=4
layout_margin=6
scrollbar_in_view=true
transient_scrollbar=false
transient_groove=true
submenu_overlap=0
tooltip_delay=-1
tree_branch_line=true
no_window_pattern=false
opaque=kaffeine,kmplayer,subtitlecomposer,kdenlive,vlc,smplayer,smplayer2,avidemux,avidemux2_qt4,avidemux2_qt5,kamoso,QtCreator,VirtualBox,trojita,dragon,digikam
reduce_window_opacity=0
respect_DE=true
scrollable_menu=false
submenu_delay=250
hide_shortcuts=false
clickable_row_height=24

[GeneralColors]
window.color=#090318
base.color=#070216
alternate.base.color=#2D4A5C
tooltip.base.color=#090318
text.color=#8BA7A7
window.text.color=#8BA7A7
button.text.color=#8BA7A7
disabled.text.color=#495495
tooltip.text.color=#8BA7A7
highlight.color=#61E2FF
highlighted.text.color=#090318
link.color=#61E2FF
link.visited.color=#AF6DF9
selection.color=#2D4A5C
selection.text.color=#8BA7A7

[Hacks]
transparent_ktitle_label=true
transparent_dolphin_view=true
transparent_pcmanfm_sidepane=true
blur_translucent=true
transparent_menutitle=true
respect_darkness=true
force_size_grip=true
iconless_pushbutton=true
iconless_menu=false
disabled_icon_opacity=96
lxqtmainmenu_iconsize=22
normal_default_pushbutton=true
single_top_toolbar=true
tint_on_mouseover=15
transparent_pcmanfm_view=true
# Wayland/Hyprland optimizations
wayland_blur_region=true
composite_blur=true
# Optional transparency settings
window_opacity=95
menu_opacity=90
tooltip_opacity=85
popup_opacity=90

[PanelButtonCommand]
frame=false
interior=true
interior.element=button
interior.px=1
interior.py=1
indicator.size=8
